#!/usr/bin/env bash

## Description: Deep-record render dependencies (templates + executed PHP via Xdebug coverage) for a URL
## Usage: render-record <url> [recordKey] [runId]
## Example: "ddev render-record https://mysite.ddev.site/ home run-1"

set -eu

URL="${1:-}"
if [ -z "${URL}" ]; then
    echo "Usage: ddev render-record <url> [recordKey] [runId]" >&2
    exit 1
fi
KEY="${2:-$(basename "${URL}")}"
RUN_ID="${3:-run-$(date +%s)}"

PHP_VERSION="$(ddev exec 'php -r "echo PHP_MAJOR_VERSION.\".\".PHP_MINOR_VERSION;"')"
COVERAGE_INI="/etc/php/${PHP_VERSION}/fpm/conf.d/zzz-render-dependency-coverage.ini"

restore() {
    ddev exec "sudo rm -f ${COVERAGE_INI} && sudo supervisorctl restart php-fpm" >/dev/null 2>&1 || true
    ddev xdebug off >/dev/null 2>&1 || true
}
trap restore EXIT

echo "[render-record] enabling Xdebug coverage on php-fpm (${PHP_VERSION})…"
ddev xdebug on >/dev/null
ddev exec "echo 'xdebug.mode=coverage' | sudo tee ${COVERAGE_INI} >/dev/null && sudo supervisorctl restart php-fpm" >/dev/null

echo "[render-record] recording ${URL} (key=${KEY}, run=${RUN_ID})…"
STATUS="$(curl -sk \
    -H "X-Render-Record: ${KEY}" \
    -H "X-Render-Run: ${RUN_ID}" \
    -H "X-Render-Depth: deep" \
    "${URL}" -o /dev/null -w '%{http_code}')"
echo "[render-record] HTTP ${STATUS}"

# Resolve the output directory exactly like the extension's middleware does:
# extension configuration outputDirectory (absolute, or relative to projectRoot),
# empty means <project>/var/render-dependency-recorder.
OUTPUT_DIR="$(ddev exec php -- <<'PHP'
<?php
$settings = @include 'config/system/settings.php';
$config = is_array($settings) ? ($settings['EXTENSIONS']['render_dependency_recorder'] ?? []) : [];
$directory = trim((string)($config['outputDirectory'] ?? ''));
$projectRoot = rtrim(trim((string)($config['projectRoot'] ?? '')), '/');
if ($projectRoot === '') {
    $projectRoot = getcwd();
}
if ($directory === '') {
    echo 'var/render-dependency-recorder';
} elseif (str_starts_with($directory, '/')) {
    echo rtrim($directory, '/');
} else {
    echo $projectRoot . '/' . trim($directory, '/');
}
PHP
)"

RUN_DIR="${OUTPUT_DIR}/requests/${RUN_ID}"
FILE_COUNT="$(ddev exec "find '${RUN_DIR}' -name '*.json' 2>/dev/null | wc -l" | tr -d '[:space:]' || true)"
if [ "${FILE_COUNT:-0}" -gt 0 ]; then
    echo "[render-record] ${FILE_COUNT} request file(s) written under ${RUN_DIR}/"
else
    echo "[render-record] WARNING: no request file found under ${RUN_DIR}/" >&2
    echo "  Possible causes: application context not in activeContexts (default: Testing)" >&2
    echo "  or the record header was stripped before reaching PHP." >&2
    exit 1
fi
